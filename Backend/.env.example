# Server Configuration
PORT=5000

# Node Environment: development | production | test
NODE_ENV=development

# MongoDB Connection
# Local development:
MONGO_URI=mongodb://localhost:27017/TogglenestDB
# MongoDB Atlas (production) — include the database name in the path:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/TogglenestDB?retryWrites=true&w=majority

# JWT
# Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_64_byte_random_hex_string
JWT_EXPIRE=7d

# CORS Origins (comma-separated for multiple)
# Dev:    CORS_ORIGIN=http://localhost:3000
# Prod:   CORS_ORIGIN=https://your-app.vercel.app
# Mixed:  CORS_ORIGIN=http://localhost:3000,https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3000
